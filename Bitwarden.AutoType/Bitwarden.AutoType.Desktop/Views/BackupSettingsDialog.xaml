<mah:MetroWindow x:Class="Bitwarden.AutoType.Desktop.Views.BackupSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Backup Settings" 
        Height="550" 
        Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinHeight="380"
        MinWidth="420"
        ShowIconOnTitleBar="False"
        ShowMaxRestoreButton="False"
        ShowMinButton="False">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Backup Folder Section -->
        <GroupBox Grid.Row="0" Header="Backup Location" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <TextBlock Text="Configured backup folder:" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="BackupFolderTextBox" 
                             Grid.Column="0"
                             mah:TextBoxHelper.Watermark="Leave empty for default location"
                             Height="30"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" 
                            Content="Browse..." 
                            Margin="10,0,0,0"
                            Padding="15,5"
                            Click="BrowseFolder_Click"/>
                </Grid>
                <TextBlock x:Name="DefaultFolderText" 
                           Text="Default: " 
                           Foreground="Gray" 
                           FontSize="11" 
                           Margin="0,5,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </GroupBox>

        <!-- Scheduled Backup Section -->
        <GroupBox Grid.Row="1" Header="Scheduled Backups" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <CheckBox x:Name="EnableScheduledCheckBox" 
                          Content="Enable scheduled backups" 
                          Margin="0,0,0,10"/>
                
                <StackPanel x:Name="SchedulePanel" Margin="20,0,0,0">
                    <TextBlock Text="Schedule (cron expression):" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ScheduleComboBox" 
                              IsEditable="True"
                              Height="30"
                              Margin="0,0,0,5">
                        <ComboBoxItem Content="0 0 * * *" Tag="Daily at midnight"/>
                        <ComboBoxItem Content="0 2 * * *" Tag="Daily at 2:00 AM"/>
                        <ComboBoxItem Content="0 */6 * * *" Tag="Every 6 hours"/>
                        <ComboBoxItem Content="0 */12 * * *" Tag="Every 12 hours"/>
                        <ComboBoxItem Content="0 0 * * 0" Tag="Weekly on Sunday"/>
                        <ComboBoxItem Content="0 0 1 * *" Tag="Monthly on the 1st"/>
                    </ComboBox>
                    <TextBlock x:Name="ScheduleDescriptionText" 
                               Text="(Daily at midnight)" 
                               Foreground="Gray" 
                               FontSize="11"/>
                    
                    <TextBlock Text="Backup password for scheduled backups:" Margin="0,15,0,5"/>
                    <PasswordBox x:Name="ScheduledPasswordBox"
                                 mah:TextBoxHelper.Watermark="Required for scheduled backups"
                                 Height="30"/>
                    <TextBlock Text="This password will be stored securely for automated backups."
                               Foreground="Gray"
                               FontSize="11"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Retention Policy Section -->
        <GroupBox Grid.Row="2" Header="Retention Policy" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Keep the most recent backups:" VerticalAlignment="Center"/>
                    <mah:NumericUpDown x:Name="RetentionCountUpDown" 
                                       Grid.Column="1"
                                       Minimum="0" 
                                       Maximum="100"
                                       Value="10"
                                       Height="30"/>
                </Grid>
                <TextBlock Text="Set to 0 to keep all backups (no count limit)"
                           Foreground="Gray"
                           FontSize="11"
                           Margin="0,3,0,10"/>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Delete backups older than (days):" VerticalAlignment="Center"/>
                    <mah:NumericUpDown x:Name="RetentionDaysUpDown" 
                                       Grid.Column="1"
                                       Minimum="0" 
                                       Maximum="365"
                                       Value="30"
                                       Height="30"/>
                </Grid>
                <TextBlock Text="Set to 0 to disable age-based deletion"
                           Foreground="Gray"
                           FontSize="11"
                           Margin="0,3,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Notifications Section -->
        <GroupBox Grid.Row="3" Header="Notifications" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <CheckBox x:Name="ShowNotificationsCheckBox" 
                          Content="Show notification when scheduled backup completes"
                          IsChecked="True"/>
            </StackPanel>
        </GroupBox>

        <!-- Status Section -->
        <StackPanel Grid.Row="4" VerticalAlignment="Bottom">
            <TextBlock x:Name="LastBackupText" 
                       Text="Last backup: Never" 
                       Foreground="Gray"
                       FontSize="11"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="5" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Cancel" 
                    Width="80" 
                    Margin="0,0,10,0"
                    Click="CancelButton_Click"/>
            <Button Content="Save" 
                    Width="80" 
                    IsDefault="True"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</mah:MetroWindow>
