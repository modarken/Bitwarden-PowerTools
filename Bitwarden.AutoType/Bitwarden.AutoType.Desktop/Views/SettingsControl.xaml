<UserControl x:Class="Bitwarden.AutoType.Desktop.Views.SettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helpers="clr-namespace:Bitwarden.AutoType.Desktop.Helpers"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,8">
            <Border Padding="14" Margin="0,0,0,12" BorderThickness="1" CornerRadius="6" BorderBrush="#33000000">
                <StackPanel>
                    <TextBlock Text="Account Settings" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="These values are saved on this device. Changing the server or account will require re-authorization."
                               Margin="0,4,0,12"
                               Foreground="Gray"
                               TextWrapping="Wrap" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Base Address:" Grid.Row="0" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" />
                        <TextBox Grid.Row="0" Grid.Column="2"
                                 Margin="0,0,0,8"
                                 Text="{Binding BitwardenClientConfiguration.base_address, Mode=TwoWay}"
                                 Style="{StaticResource MahApps.Styles.TextBox}" />

                        <TextBlock Text="Email:" Grid.Row="1" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" />
                        <TextBox Grid.Row="1" Grid.Column="2"
                                 Margin="0,0,0,8"
                                 Text="{Binding BitwardenClientConfiguration.email, Mode=TwoWay}"
                                 Style="{StaticResource MahApps.Styles.TextBox}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" />
                        <CheckBox Grid.Row="2" Grid.Column="2"
                                  Margin="0,0,0,4"
                                  IsChecked="{Binding BitwardenClientConfiguration.AllowInvalidCertificates, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ShieldAlert" Foreground="Orange" Width="16" Height="16" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Allow Invalid SSL Certificates (for self-hosted with self-signed certs)" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </CheckBox>
                    </Grid>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Save Settings"
                                Command="{Binding SaveSettingsCommand}"
                                Margin="0,0,8,8"
                                Style="{DynamicResource MahApps.Styles.Button.Square}" />
                        <Button Content="Open Windows Startup Apps"
                                Command="{Binding OpenStartupAppsSettingsCommand}"
                                Margin="0,0,0,8"
                                Style="{DynamicResource MahApps.Styles.Button}" />
                    </WrapPanel>

                    <TextBlock Text="Use Windows Settings to enable or disable startup for Bitwarden AutoType."
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Border>

            <Border Padding="14" Margin="0,0,0,12" BorderThickness="1" CornerRadius="6" BorderBrush="#33000000">
                <StackPanel>
                    <TextBlock Text="Authorization State" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Authorization is stored separately from your saved account settings. The master password is only used during authorization."
                               Margin="0,4,0,12"
                               Foreground="Gray"
                               TextWrapping="Wrap" />

                    <TextBlock Text="{Binding AuthorizationStatusText}" FontWeight="Bold" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding AuthorizationMethodText}" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding AuthorizationDetailText}" TextWrapping="Wrap" />

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Authorize With API Key"
                                Command="{Binding BeginApiKeyAuthorizationCommand}"
                                IsEnabled="{Binding CanStartAuthorization}"
                                Margin="0,0,8,8"
                                Style="{DynamicResource MahApps.Styles.Button.Square}" />
                        <Button Content="Authorize With Password"
                                Command="{Binding BeginPasswordAuthorizationCommand}"
                                IsEnabled="{Binding CanStartAuthorization}"
                                Margin="0,0,8,8"
                                Style="{DynamicResource MahApps.Styles.Button.Square}" />
                        <Button Content="Clear Stored Authorization"
                                Command="{Binding ClearStoredAuthorizationCommand}"
                                IsEnabled="{Binding CanClearStoredAuthorization}"
                                Margin="0,0,0,8"
                                Style="{DynamicResource MahApps.Styles.Button}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Padding="14"
                    BorderThickness="1"
                    CornerRadius="6"
                    BorderBrush="#33000000"
                    Visibility="{Binding IsAuthorizationInputVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Authorization Input" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Enter one-time authorization input below. Nothing in this section is treated like a normal saved setting."
                               Margin="0,4,0,12"
                               Foreground="Gray"
                               TextWrapping="Wrap" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Master Password:" Grid.Row="0" Grid.Column="0" Margin="0,0,0,8" VerticalAlignment="Center" />
                        <PasswordBox Grid.Row="0" Grid.Column="2"
                                     Margin="0,0,0,8"
                                     helpers:PasswordBoxBindingBehavior.PasswordBinding="{Binding MasterPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MahApps.Styles.PasswordBox}" />

                        <StackPanel Grid.Row="1" Grid.Column="2"
                                    Visibility="{Binding IsApiKeyInputVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Client ID:" Margin="0,0,0,4" />
                            <TextBox Text="{Binding AuthorizationClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8"
                                     Style="{StaticResource MahApps.Styles.TextBox}" />
                            <TextBlock Text="Client Secret:" Margin="0,0,0,4" />
                            <PasswordBox helpers:PasswordBoxBindingBehavior.PasswordBinding="{Binding AuthorizationClientSecret, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource MahApps.Styles.PasswordBox}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2"
                                    Visibility="{Binding IsPasswordInputVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="TOTP (optional):" Margin="0,0,0,4" />
                            <TextBox Text="{Binding Totp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MahApps.Styles.TextBox}" />
                        </StackPanel>
                    </Grid>

                    <WrapPanel Margin="0,12,0,0">
                        <Button Content="Confirm Authorization"
                                Command="{Binding CompleteAuthorizationCommand}"
                                Margin="0,0,8,0"
                                Style="{DynamicResource MahApps.Styles.Button.Square}" />
                        <Button Content="Cancel"
                                Command="{Binding CancelAuthorizationInputCommand}"
                                Style="{DynamicResource MahApps.Styles.Button}" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>